# Telegram bot token for @gamepairingbot (from BotFather).
# Used only by local admin scripts to configure the bot via the Bot API;
# the client-side app never sees or ships this value.
SWISSPAIR_TG_TOKEN=

# Supabase project (multi-user session backend). URL + publishable key are
# client-safe; the SECRET key is server-side only (Edge Functions receive
# these automatically — never put the secret key in the page).
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=
